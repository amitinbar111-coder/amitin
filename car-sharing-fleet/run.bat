@echo off
title צי רכב שיתופי - שרת פיתוח מקומי
echo ===================================================
echo   מפעיל שרת פיתוח מקומי עבור אפליקציית צי רכב שיתופי
echo   האפליקציה תהיה זמינה בכתובת: http://localhost:8000
echo   כדי לעצור את השרת, סגור חלון זה.
echo ===================================================
echo.

:: פתיחת הדפדפן בכתובת המקומית
start http://localhost:8000

:: הפעלת שרת ה-HTTP של פייתון
py -m http.server 8000
if %ERRORLEVEL% neq 0 (
    echo ניסיון הפעלה חלופי באמצעות פקודת python...
    python -m http.server 8000
)

pause
